generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())

  clothing ClothingItem[]
  outfits  Outfit[]
}

model ClothingItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  category    String
  subcategory String   @default("")
  colors      String
  colorHex    String
  style       String
  season      String
  description String
  tags        String
  imageData   String   @db.Text
  thumbnail   String   @db.Text
  createdAt   DateTime @default(now())
}

model Outfit {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  itemIds     String
  name        String
  description String
  occasion    String
  colorScheme String
  stylingTip  String
  createdAt   DateTime @default(now())
}
